# AgentHub Backend Environment Configuration
#
# Copy this file: cp .env.example .env
# Edit .env to add your 3rd-party API keys (Tavily, Amap, LangSmith, etc.)
# LLM API keys are configured in Web UI (http://localhost:5173 -> Settings)
#
# =============================================================================
# 📦 MODE DRIVEN CONFIGURATION
# =============================================================================
#
# Application mode: dev | prod
#   dev  -> SQLite + sqlite-vec + InMemoryStore (local dev/test, LangSmith allowed)
#   prod -> PostgreSQL + pgvector + AsyncPostgresStore (production deployment)
MODE=dev

# DATABASE_TYPE and VECTORSTORE_TYPE are AUTOMATICALLY determined by MODE:
#   - dev  -> DATABASE_TYPE=sqlite, VECTORSTORE_TYPE=sqlite_vec
#   - prod -> DATABASE_TYPE=postgres, VECTORSTORE_TYPE=pgvector
# They cannot be set independently — configure PostgreSQL below for prod mode.

# Web server configuration
HOST=0.0.0.0
PORT=8080

# =============================================================================
# System-level Default LLM (Required)
# =============================================================================
# Used by agents at compile time, and by all internal/implicit LLM calls
# (long-term memory extraction, conversation summarization, title generation,
# etc.). Users can dynamically switch models at runtime per-request, but this
# is the always-available system fallback.
#
# DEFAULT_LLM_MODEL format: "provider/model-id" (e.g. "zai/glm-5.1", "openai/gpt-4o")
DEFAULT_LLM_MODEL=zai/glm-5.1
DEFAULT_LLM_API_KEY=0cae2d2a671a4994***********ebec.Smc4OYRYjWQ13VLB

# =============================================================================
# 🔐 API Key Encryption (REQUIRED for ALL environments)
# =============================================================================
# Encryption key for API keys stored in database
# This is a 256-bit AES key (32 characters)
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_urlsafe(24)[:32])"
#
# DEV MODE EXAMPLE (for local development only — do NOT use this in production!):
#   API_KEY_ENCRYPTION_KEY=DevOnlyKey!ChangeMe2026!
#
# For production, generate your own key using the command above!
API_KEY_ENCRYPTION_KEY=

# =============================================================================
# LangSmith Tracing Configuration (Optional)
# =============================================================================
# NOTE: LangSmith tracing is ONLY allowed in dev mode!
# Prod mode will have tracing force-disabled for security.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT="AgentHub"
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=

# =============================================================================
# PostgreSQL Configuration (required when MODE == prod)
# =============================================================================
POSTGRES_USER=langchain
POSTGRES_PASSWORD=langgraph
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentdb

# PostgreSQL SSL Configuration
# SSL mode for PostgreSQL connections:
#   disable: No SSL (not recommended for production)
#   prefer: Try SSL first, fallback to plaintext (default)
#   require: Always use SSL, no certificate verification
#   verify-ca: Always use SSL, verify server certificate
#   verify-full: Always use SSL, verify full certificate chain
POSTGRES_SSL_MODE=prefer

# SQLite Configuration (used when MODE == dev)
# Note: Docker overrides this to /app/data/agenthub.db (volume-mounted)
SQLITE_DATABASE_PATH=./data/agenthub.db

# Default embedding dimension for vector databases
EMBEDDING_DIMENSION=1024

# =============================================================================
# WebSocket Configuration
# =============================================================================
WS_ENABLED=false
WS_HEARTBEAT_INTERVAL=30

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of origins allowed for CORS
# Dev mode default: http://localhost:5173 (Vite dev server)
# Production should include your frontend domain(s)
# Example: CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level for application logging
# DEBUG: Detailed debug information
# INFO: General information (default)
# WARNING: Warning messages
# ERROR: Error messages
LOG_LEVEL=INFO

# =============================================================================
# Tavily Search API (Optional, required for web search tool)
# =============================================================================
TAVILY_API_KEY=

# =============================================================================
# Amap (Gaode Maps) Configuration (Optional)
# =============================================================================
# Get your API key from: https://lbs.amap.com/api/webservice/guide/create-project/get-key
AMAP_KEY=