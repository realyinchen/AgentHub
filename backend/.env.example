# AgentHub Backend Environment Configuration
#
# =============================================================================
# 🐳 DOCKER DEPLOYMENT
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env to add your 3rd-party API keys (Tavily, Amap, LangSmith, etc.)
# 3. LLM API keys are configured in Web UI (http://localhost:5173 → Settings)
# 4. Start: docker-compose up -d
#
# For PostgreSQL mode (--profile postgres), change:
#   - DATABASE_TYPE=postgres
#   - VECTORSTORE_TYPE=qdrant
#   - POSTGRES_HOST=postgres        (NOT localhost - this is Docker service name)
#   - QDRANT_HOST=qdrant            (NOT localhost - this is Docker service name)
#
# =============================================================================
# 💻 LOCAL DEVELOPMENT (python run_backend.py)
# =============================================================================
# Same .env file works for both Docker and local development!
#
# Application mode: dev enables uvicorn auto-reload
MODE=env

# Web server configuration
HOST=0.0.0.0
PORT=8080

# =============================================================================
# Model Providers Configuration
# =============================================================================
# Available model providers for frontend dropdown
# Supported: dashscope (Alibaba Cloud), zai (ZhipuAI)
MODEL_PROVIDERS=["dashscope", "zai"]

# =============================================================================
# LangSmith Tracing Configuration (Optional)
# =============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT="AgentHub"
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=

# =============================================================================
# Database Configuration
# =============================================================================
# Database type: postgres | sqlite
# Default: sqlite (zero external dependencies, recommended for quick start)
DATABASE_TYPE=sqlite

# PostgreSQL Configuration (used when DATABASE_TYPE=postgres)
POSTGRES_USER=langchain
POSTGRES_PASSWORD=langgraph
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentdb

# SQLite Configuration (used when DATABASE_TYPE=sqlite)
# Note: Docker overrides this to /app/data/agenthub.db (volume-mounted)
SQLITE_DATABASE_PATH=./data/agenthub.db

# =============================================================================
# Vector Store Configuration
# =============================================================================
# Vector store type: qdrant | sqlite_vec
# Default: sqlite_vec (zero external dependencies)
VECTORSTORE_TYPE=sqlite_vec

# Qdrant Configuration (used when VECTORSTORE_TYPE=qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=agentic_rag_survey

# SQLite Vec Configuration (used when VECTORSTORE_TYPE=sqlite_vec)
# Note: Docker overrides this to /app/data/agenthub_vec.db (volume-mounted)
SQLITE_VEC_DATABASE_PATH=./data/agenthub_vec.db

# =============================================================================
# Tavily Search API (required for web search tool)
# =============================================================================
TAVILY_API_KEY=

# =============================================================================
# Amap (Gaode Maps) Configuration
# =============================================================================
# Get your API key from: https://lbs.amap.com/api/webservice/guide/create-project/get-key
AMAP_KEY=

# =============================================================================
# API Key Encryption Configuration
# =============================================================================
# Encryption key for API keys stored in database (must match frontend)
# Default: AgentHub2026SecureKey!@#$% (32 chars = 256-bit AES key)
# WARNING: Change this in production for security!
API_KEY_ENCRYPTION_KEY=AgentHub2026SecureKey!@#$%