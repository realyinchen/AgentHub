# Application mode. If the value is "dev", it will enable uvicorn reload
MODE=dev

# Web server configuration
HOST=0.0.0.0
PORT=8080

# =============================================================================
# Model Providers Configuration
# =============================================================================
# Available model providers for frontend dropdown
# Supported: dashscope (Alibaba Cloud), zai (ZhipuAI)
MODEL_PROVIDERS=["dashscope", "zai"]

# =============================================================================
# Embedding Model Configuration
# =============================================================================
# Embedding model for vector store (using LiteLLM format)
EMBEDDING_MODEL_NAME=dashscope/text-embedding-v4
EMBEDDING_API_KEY=sk-d2a977************************

# =============================================================================
# LangSmith Configuration
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="AgentHub"
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=langchain
POSTGRES_PASSWORD=langgraph
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentdb

# =============================================================================
# Qdrant Configuration
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=agentic_rag_survey

# =============================================================================
# Tavily Search API
# =============================================================================
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Amap (Gaode Maps) Configuration
# =============================================================================
# Get your API key from: https://lbs.amap.com/api/webservice/guide/create-project/get-key
AMAP_KEY=your_amap_api_key_here

# =============================================================================
# API Key Encryption Configuration
# =============================================================================
# Encryption key for API keys stored in database (must match frontend)
# Default: AgentHub2026SecureKey!@#$% (32 chars = 256-bit AES key)
# WARNING: Change this in production for security!
API_KEY_ENCRYPTION_KEY=AgentHub2026SecureKey!@#$%
