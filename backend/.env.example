# Application mode. If the value is "dev", it will enable uvicorn reload
MODE=dev

# Web server configuration
HOST=0.0.0.0
PORT=8080

# =============================================================================
# LLM Configuration - Multi-model via LLM_MODELS (Recommended)
# =============================================================================
LLM_MODELS=[{"model_name":"default","litellm_params":{"model":"dashscope/kimi-k2.5","api_key":"sk-f9aba4424ae0**********b9f190a9","api_base":"https://dashscope.aliyuncs.com/compatible-mode/v1"}},{"model_name":"thinking","litellm_params":{"model":"dashscope/qwen3.5-27b","api_key":"sk-f9aba4424ae047**************f190a9","api_base":"https://dashscope.aliyuncs.com/compatible-mode/v1","extra_body":{"enable_thinking":true}}}]

LLM_DEFAULT_MODEL=default
LLM_THINKING_MODEL=thinking

# Embedding model
EMBEDDING_MODEL_NAME=text-embedding-v4

# =============================================================================
# LangSmith Configuration
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="AgentHub"
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_6e65597345d******************4e16b8_750c09da89

# =============================================================================
# PostgreSQL Configuration
