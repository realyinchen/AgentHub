# Application mode. If the value is "dev", it will enable uvicorn reload
MODE=dev

# Web server configuration
HOST=0.0.0.0
PORT=8080

# =============================================================================
# LLM Configuration - Multi-model via LLM_MODELS (Recommended)
# =============================================================================
# Model Naming Convention:
#   - Regular models: any name without "thinking" suffix (e.g., "default", "gpt-4", "glm-4")
#   - Thinking models: name MUST end with "thinking" (e.g., "deepseek-thinking", "qwen-thinking")
#   - The "thinking" suffix determines if the model appears in thinking mode selector in UI
#
# Supported providers: dashscope (Alibaba Cloud), zai (Zhipu) etc.
# See LiteLLM documentation for full provider list: https://docs.litellm.ai/docs/providers

LLM_MODELS=[{"model_name":"qwen3.5-27b","litellm_params":{"model":"dashscope/qwen3.5-27b","api_key":"***************","extra_body":{"enable_thinking":false}}},{"model_name":"qwen3.5-flash-thinking","litellm_params":{"model":"dashscope/qwen3.5-flash-2026-02-23","api_key":"***************","extra_body":{"enable_thinking":true}}},{"model_name":"glm5","litellm_params":{"model":"zai/glm-5","api_key":"***************","extra_body":{"thinking":{"type":"disabled"}}}},{"model_name":"glm5-thinking","litellm_params":{"model":"zai/glm-5","api_key":"***************","extra_body":{"thinking":{"type":"enabled"}}}}]

# Default model for regular chat (must match a model_name in LLM_MODELS)
LLM_DEFAULT_MODEL=qwen3.5-27b
# Default thinking model (must match a model_name ending with "thinking")
LLM_THINKING_MODEL=qwen3.5-flash-thinking

# Embedding model
EMBEDDING_MODEL_NAME=text-embedding-v4

# =============================================================================
# LangSmith Configuration
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="AgentHub"
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
# Note: For Docker deployment, use host.docker.internal instead of localhost
# - Local development: POSTGRES_HOST=localhost
# - Docker standalone backend: POSTGRES_HOST=host.docker.internal
# - Docker one-click (docker-compose.yml): overridden to postgres
POSTGRES_USER=langchain
POSTGRES_PASSWORD=langgraph
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentdb

# =============================================================================
# Qdrant Configuration
# =============================================================================
# Note: For Docker deployment, use host.docker.internal instead of localhost
# - Local development: QDRANT_HOST=localhost
# - Docker standalone backend: QDRANT_HOST=host.docker.internal
# - Docker one-click (docker-compose.yml): overridden to qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=agentic_rag_survey

# =============================================================================
# Tavily Search API
# =============================================================================
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Amap (Gaode Maps) Configuration
# =============================================================================
# Get your API key from: https://lbs.amap.com/api/webservice/guide/create-project/get-key
AMAP_KEY=your_amap_api_key_here