# AgentHub Frontend Environment Configuration
#
# =============================================================================
# 🐳 DOCKER DEPLOYMENT
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env if you need to change defaults (usually not needed if running
#    frontend and backend on the same server)
# 3. Start: docker-compose up -d
#
# =============================================================================
# 💻 LOCAL DEVELOPMENT (npm run dev)
# =============================================================================
# Same .env file works for both Docker and local development!

# =============================================================================
# Local Development (Vite)
# =============================================================================

# Backend API Base URL (used by frontend code)
# Default: /api/v1 (relative path, uses vite proxy in dev or nginx proxy in docker)
VITE_API_BASE_URL=/api/v1

# Vite dev server proxy target (used only in local development)
# Change this if your backend runs on a different host/port
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080

# =============================================================================
# Docker Deployment (Nginx)
# =============================================================================

# Backend address for nginx proxy (used in Docker deployment)
# Default: backend (Docker service name, works when frontend and backend run
# on the same server in the same compose stack)
# Change this to your backend server IP/domain if deploying to different servers
NGINX_BACKEND_HOST=backend
NGINX_BACKEND_PORT=8080

# Frontend exposed port (mapped from nginx port 80 inside container)
FRONTEND_PORT=5173