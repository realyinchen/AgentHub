# Frontend Environment Variables
# For local development, copy this file to .env

# =============================================================================
# Local Development (Vite)
# =============================================================================

# Backend API Base URL (used by frontend code)
# Default: /api/v1 (relative path, uses vite proxy in dev or nginx proxy in docker)
VITE_API_BASE_URL=/api/v1

# Vite dev server proxy target (used only in local development)
# Change this if your backend runs on a different host/port
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080

# =============================================================================
# Docker Deployment (Nginx)
# =============================================================================

# Backend address for nginx proxy (used in Docker deployment)
# Change this to your backend server address
NGINX_BACKEND_HOST=host.docker.internal
NGINX_BACKEND_PORT=8080

# Frontend exposed port
FRONTEND_PORT=5173